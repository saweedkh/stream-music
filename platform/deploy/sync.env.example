# Copy to deploy/sync.env (gitignored) and fill in your server.
# cp deploy/sync.env.example deploy/sync.env
#
# Prefer SSH keys (ssh-copy-id) and leave SSH_PASSWORD empty.
# For password auth install: brew install hudochenkov/sshpass/sshpass

REMOTE_HOST=localhost
REMOTE_USER=root
# Leave empty to auto-detect on the server, or set explicitly:
REMOTE_PATH=/root/stream-music
SSH_PORT=22

# Optional — only if you do not use SSH keys:
# SSH_PASSWORD=your-password-here
