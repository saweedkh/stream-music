# Copy to .env.edge before ./up.sh
# cp deploy/edge-proxy/env.example deploy/edge-proxy/.env.edge

# Full origin of the central server (no trailing slash).
# Examples:
#   UPSTREAM_URL=https://music.example.com
#   UPSTREAM_URL=https://203.0.113.10
#   UPSTREAM_URL=http://203.0.113.10:8080
UPSTREAM_URL=https://music.example.com

# Port exposed on this machine for LAN clients (phones / laptops on Wi‑Fi).
EDGE_PORT=9080

# On-disk cache for /audio/ (reduces repeated internet downloads on LAN).
CACHE_MAX_SIZE=50g
CACHE_INACTIVE=30d

# Set to 0 when upstream uses self-signed / private CA HTTPS.
PROXY_SSL_VERIFY=0
