# Copy to project root as `.env.production` before ./deploy/up.sh
#
# cp deploy/env.production.example .env.production

DEBUG=0
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost

POSTGRES_DB=stream_music
POSTGRES_USER=stream_music
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
MEDIA_ROOT=/media

# yt-dlp proxy when YouTube/SoundCloud are blocked on the server (VPN HTTP proxy on the host).
# Required on many networks for Spotify/YouTube import. Example:
# YTDLP_PROXY=http://127.0.0.1:7890
#
# On the host, run your VPN/proxy so this address is reachable from Docker backend/celery.

# Optional error tracking (no-op when unset)
# SENTRY_DSN=https://…@sentry.io/…
# SENTRY_ENVIRONMENT=production
# NEXT_PUBLIC_SENTRY_DSN=https://…@sentry.io/…
# SENTRY_ORG=your-org
# SENTRY_PROJECT=stream-music-web

# Optional: pin the host/IP used in nginx + Django ALLOWED_HOSTS/CORS when auto-detect is wrong (LAN/VPN).
# PRIMARY_IP=192.168.1.50

# Hostname users open in the browser (must match cert SAN when using HTTPS).
# SITE_DOMAIN=music.saweedkh.ir

# Certbot folder name under live/ (cert you issued: /etc/letsencrypt/live/<name>/).
# Leave empty or remove if /etc/letsencrypt/live/<name>/ is not on this host yet.
TLS_CERT_NAME=saweedkh.ir
# TLS_CERT_DIR=/etc/letsencrypt/live
# TLS_CERT_HOST_DIR=/etc/letsencrypt

# Optional exact origins (deploy script also sets CORS_EXTRA_ORIGINS from PRIMARY_IP / SITE_DOMAIN).
CORS_EXTRA_ORIGINS=

# Use 0 for http://PRIMARY_IP:8080 (prod LAN HTTP). Keep 1 if clients only use HTTPS (:443/:8443).
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1

# Web Push — same public key as NEXT_PUBLIC_WEBPUSH_VAPID_PUBLIC_KEY in frontend build (or rely on GET /api/auth/me).
FRONTEND_BASE_URL=
WEBPUSH_VAPID_PUBLIC_KEY=BD-yFmmlVLYRgW8U60CnOFCIHQ1YlBw2G7t-obUl4TnG5wttznz5jpmEZT9lx_aA4To7AcniJ7JSLtPZdBZyfD0
WEBPUSH_VAPID_PRIVATE_KEY=ub5xautjzxA4ghntr469GXx7VAGAQu9pqvA9it8Tiq8
WEBPUSH_VAPID_SUBJECT=mailto:admin@stream-music.local
NEXT_PUBLIC_WEBPUSH_VAPID_PUBLIC_KEY=BD-yFmmlVLYRgW8U60CnOFCIHQ1YlBw2G7t-obUl4TnG5wttznz5jpmEZT9lx_aA4To7AcniJ7JSLtPZdBZyfD0
