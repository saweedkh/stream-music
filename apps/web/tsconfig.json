{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/shared/ui/*": ["src/shared/ui/*"],
      "@/shared/layout/*": ["src/shared/layout/*"],
      "@/shared/hooks/*": ["src/shared/hooks/*"],
      "@/shared/providers/*": ["src/shared/providers/*"],
      "@/shared/notifications/*": ["src/shared/notifications/*"],
      "@/shared/pwa/*": ["src/shared/pwa/*"],
      "@/shared/room/*": ["src/shared/room/*"],
      "@/components/ui/*": ["src/shared/ui/*"],
      "@/components/layout/*": ["src/shared/layout/*"],
      "@/components/providers/*": ["src/shared/providers/*"],
      "@/components/notifications/*": ["src/shared/notifications/*"],
      "@/components/room/*": ["src/shared/room/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
