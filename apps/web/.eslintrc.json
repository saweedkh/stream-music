{
  "extends": "next/core-web-vitals",
  "rules": {
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": ["@/features/*/**"],
            "message": "Import from feature public API (@/features/<name>) instead of deep paths."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/features/auth/**/*"],
      "rules": {
        "no-restricted-imports": [
          "warn",
          {
            "patterns": [
              {
                "group": [
                  "@/features/channels/**",
                  "@/features/dashboard/**",
                  "@/features/discovery/**",
                  "@/features/experience/**",
                  "@/features/party/**",
                  "@/features/player/**",
                  "@/features/playlists/**"
                ],
                "message": "Import from @/features/<name> public API, not deep paths."
              }
            ]
          }
        ]
      }
    },
