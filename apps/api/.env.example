DEBUG=1
SECRET_KEY=dev-secret-key
ALLOWED_HOSTS=*
# Trust RFC1918 LAN origins for CSRF/CORS regex (use with Docker/LAN HTTPS). Set 0 in production.
TRUST_LAN_CSRF=1
# Exact origins for CSRF + CORS on LAN (comma-separated). Optional if TRUST_LAN_CSRF=1 or DEBUG matches regex.
# Example: CORS_EXTRA_ORIGINS=https://172.20.10.2:8443,http://172.20.10.2:8080
CORS_EXTRA_ORIGINS=
POSTGRES_DB=stream_music
POSTGRES_USER=stream_music
POSTGRES_PASSWORD=stream_music
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
# Web Push (VAPID) — dev keys; run scripts/generate-vapid-keys.sh to rotate.
# App URL for notification deep links (use nginx :8080 when using docker compose).
FRONTEND_BASE_URL=http://localhost:8080
WEBPUSH_VAPID_PUBLIC_KEY=BD-yFmmlVLYRgW8U60CnOFCIHQ1YlBw2G7t-obUl4TnG5wttznz5jpmEZT9lx_aA4To7AcniJ7JSLtPZdBZyfD0
WEBPUSH_VAPID_PRIVATE_KEY=ub5xautjzxA4ghntr469GXx7VAGAQu9pqvA9it8Tiq8
WEBPUSH_VAPID_SUBJECT=mailto:admin@stream-music.local
