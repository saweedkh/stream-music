# Copy to project root as `.env.production` before ./deploy/up.sh
#
# cp deploy/env.production.example .env.production

DEBUG=0
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=localhost

POSTGRES_DB=stream_music
POSTGRES_USER=stream_music
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
MEDIA_ROOT=/media

# Optional exact origins (deploy script also sets CORS_EXTRA_ORIGINS from detected IP / SITE_DOMAIN).
CORS_EXTRA_ORIGINS=

# Set SESSION_COOKIE_SECURE=0 only if you terminate TLS somewhere else and serve plain HTTP to clients.
SESSION_COOKIE_SECURE=1
CSRF_COOKIE_SECURE=1

# Optional: export SITE_DOMAIN before ./deploy/up.sh for real HTTPS (Let's Encrypt).
# Example: SITE_DOMAIN=music.example.com ./deploy/up.sh
